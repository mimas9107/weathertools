# Viewpoints API Configuration
# Get your credentials from https://viewpoints-4dzi.onrender.com
CWB_API_KEY=your_cwb_api_key
VIEWPOINTS_USERNAME=your_username
VIEWPOPOINTS_PASSWORD=your_password

# Optional: Override API URL if different
# VIEWPOINTS_API_URL=https://viewpoints-4dzi.onrender.com

# TDX (Transport Data eXchange) API
# Register at https://tdx.transportdata.tw/ to get Client ID / Secret
TDX_CLIENT_ID=your_tdx_client_id
TDX_CLIENT_SECRET=your_tdx_client_secret
